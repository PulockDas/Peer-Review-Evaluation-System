# ── Python ────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyd
.Python

# ── Virtual environments ───────────────────────────────────────────────────
.venv/
venv/
ENV/
env/

# ── Django ─────────────────────────────────────────────────────────────────
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal

# Collected static files (generated by collectstatic — do not commit)
staticfiles/

# User-uploaded files: student submission files, profile pictures, etc.
# These live under MEDIA_ROOT (media/) and must never be committed to git.
# They can be large, are environment-specific, and contain student work.
media/

# ── Migrations: intentionally TRACKED ─────────────────────────────────────
# Do NOT add */migrations/*.py here. Migration files are source code.

# ── Environment / secrets ──────────────────────────────────────────────────
# .env contains database credentials and Django secret key — never commit it.
.env
.env.*
!.env.example

# ── OS / editor ────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini

# ── VS Code / Cursor ───────────────────────────────────────────────────────
.vscode/*
!.vscode/launch.json
!.vscode/settings.json
!.vscode/extensions.json

# ── JetBrains ──────────────────────────────────────────────────────────────
.idea/

# ── Node (if added later) ──────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Testing / coverage ─────────────────────────────────────────────────────
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# ── Packaging / build ──────────────────────────────────────────────────────
build/
dist/
*.egg-info/
